# ============================================================
# STT-Nova2 Environment Configuration
# Copy file này thành .env và điền thông tin thực tế
#   cp .env.example .env
# ============================================================

# --- Server Config ---
HOST=0.0.0.0
PORT=8123
DEBUG_MODE=False
WEB_CONCURRENCY=2

# --- STT Configuration ---
# Options: deepgram, phowhisper, google_stt
STT_ENGINE=phowhisper
DEEPGRAM_API_KEYS=your_deepgram_key_1,your_deepgram_key_2
GOOGLE_STT_CREDENTIALS_JSON=path/to/credentials.json
AUDIO_PROCESSING_MODE=auto
MAX_WORDS=150

# --- TTS Configuration ---
# Options: vieneu (local), openai, fpt, google_tts
TTS_ENGINE=vieneu
OPENAI_API_KEY=your_openai_key
FPT_API_KEY=your_fpt_key
VIENEU_MODEL_PATH=resource/models/vieneu_model.pth

# --- Chatbot AI Configuration ---
GOOGLE_AI_MODEL=gemini-2.0-flash
# List of API Keys for Round Robin rotation (comma separated)
GOOGLE_API_KEYS=your_google_api_key_1,your_google_api_key_2
MAX_HISTORY=10

# --- Groq API (Fallback khi Gemini hết quota) ---
# Đăng ký tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id

# --- Vector Database Config (AI Memory / PgVector) ---
VECTOR_DB_USER=your_vector_db_user
VECTOR_DB_PASSWORD=your_vector_db_password
VECTOR_DB_NAME=vector_store
VECTOR_DB_HOST=vector-db
VECTOR_DB_PORT=5432

# --- PostgreSQL Configuration (External Data Source - Tổng đài) ---
POSTGRESQL_ENABLED=True
POSTGRESQL_HOST=host.docker.internal
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=fusionpbx
POSTGRESQL_USERNAME=your_pg_username
POSTGRESQL_PASSWORD=your_pg_password

# --- Webhook Domain Mapping (Cross-Server communication) ---
# Format: internal_host=public_domain (comma separated for multiple)
WEBHOOK_DOMAIN_MAPPING=

# --- Security ---
API_KEY_SECRET=your_api_secret_for_endpoints
Allowed_Hosts=*
